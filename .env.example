# Template for the docker-compose .env file. Copy this to .env and fill in:
#   cp .env.example .env
#
# Loaded into the `main` container via the `env_file` directive in docker-compose.yml.
# Internal hostnames (Pulsar, S3, Dragonfly, ASR) are pinned in docker-compose.yml's
# `environment:` block and intentionally do NOT live here.
#
# Values marked REQUIRED must be filled in or the corresponding feature breaks. Optional
# values can be left empty / commented and the feature stays disabled.

# ────────────────────────────────────────────────────────────────
# REQUIRED — Slack bot for posting alerts
# ────────────────────────────────────────────────────────────────

# Bot user OAuth token (xoxb-...) from your Slack app's "OAuth & Permissions" page.
# Needs at minimum: chat:write
SLACK_TOKEN=

# Channel ID where rescue alerts are posted (View channel details → Copy channel ID).
SLACK_CHANNEL_ID=

# ────────────────────────────────────────────────────────────────
# REQUIRED — OpenAI / OpenAI-compatible chat completion
# ────────────────────────────────────────────────────────────────

# May be empty when OPENAI_BASE_URL points at a local server (Ollama, vLLM, LiteLLM)
# that doesn't enforce auth.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=30s

# Disable Qwen3-style chain-of-thought emission via chat_template_kwargs.enable_thinking.
# Templates that don't recognize the kwarg (Gemma, Mistral) ignore it. Default off (false)
# means the kwarg is sent — flip to true if you specifically want a thinking model to think.
# OPENAI_ENABLE_THINKING=false

# Examples for OpenAI-compatible local servers (use one of these as OPENAI_BASE_URL):
# - Ollama:  http://host.docker.internal:11434/v1   (set OPENAI_MODEL=llama3.1:8b)
# - vLLM:    http://host.docker.internal:8000/v1
# - LiteLLM: http://host.docker.internal:4000/v1

# ────────────────────────────────────────────────────────────────
# Display timezone
# ────────────────────────────────────────────────────────────────
# IANA timezone for every Slack message + log timestamp the service emits.
# America/Los_Angeles handles PST/PDT automatically (default for NORCOM region).
# Set to UTC or any other IANA zone if you operate elsewhere.
# DISPLAY_TIMEZONE=America/Los_Angeles

# ────────────────────────────────────────────────────────────────
# ASR endpoint
# ────────────────────────────────────────────────────────────────
# Default below talks to the mock-asr container that docker-compose stands up. Override
# to a real ASR server when you want non-canned transcriptions:
#
# Compose-mode (default):  http://mock-asr:1080/transcribe
# Non-compose, mock:       http://localhost:1080/transcribe
# Non-compose, real ASR:   http://asr.intersect.k8s.lfp.rocks/api/v1/transcribe
ASR_ENDPOINT=http://mock-asr:1080/transcribe

# ────────────────────────────────────────────────────────────────
# OPTIONAL — Slack interactivity (Cancel / Extend buttons via Socket Mode)
# ────────────────────────────────────────────────────────────────

# App-level token (xapp-...) with the connections:write scope. Leave empty to disable.
SLACK_APP_TOKEN=

# Comma-separated Slack user IDs (UXXXXXX) permitted to press the Cancel / Extend / Switch
# buttons. Empty list = nobody can press them (safe default — feature loads but is inert).
# Set to "*" to allow ANY channel member to press the buttons (no leadership gate). The
# wildcard logs a security-relevant WARN at startup so it's not chosen accidentally.
SLACK_ALLOWED_USER_IDS=

# SLACK_CHANNEL_CLOSED_BROADCAST_ENABLED=false

# ────────────────────────────────────────────────────────────────
# OPTIONAL — Submit Feedback button on closed alerts
# ────────────────────────────────────────────────────────────────
# Set FEEDBACK_FORM_URL to a Google Form viewform URL to enable a "Submit Feedback"
# button on closed rescue alerts. FEEDBACK_FORM_FIELDS is a JSON map from logical field
# names → Google Form entry IDs. Recognized logical names: tac_channel, closed_at,
# dispatch_transcript, headline, situation_summary.
# FEEDBACK_FORM_URL=https://docs.google.com/forms/d/e/1FAIpQLSc.../viewform
# FEEDBACK_FORM_FIELDS={"tac_channel":"entry.111","closed_at":"entry.222","dispatch_transcript":"entry.333","headline":"entry.444","situation_summary":"entry.555"}

# ────────────────────────────────────────────────────────────────
# OPTIONAL — Confidential call-types list (AES-256-GCM encrypted file)
# ────────────────────────────────────────────────────────────────

# Generate the key with:  go run ./cmd/encrypt-calltypes generate-key
# Path is inside the container; ./config is mounted to /config in docker-compose.yml.
# CALL_TYPES_PATH=/config/call_types.enc
# CALL_TYPES_KEY=

# ────────────────────────────────────────────────────────────────
# Tunables (commented values are the in-code defaults)
# ────────────────────────────────────────────────────────────────

# LOG_LEVEL=info
# WORKER_COUNT=3
# WORKER_TIMEOUT=30s
# TACTICAL_CHANNEL_ACTIVATION_DURATION=30m
# TAC_SWEEPER_INTERVAL=5s
# DEDUP_TTL=1h

# PULSAR_MAX_DELIVERIES=5
# PULSAR_NACK_REDELIVERY_DELAY=30s

# TRACING_ENABLED=false
# TRACING_SAMPLERATE=1.0
